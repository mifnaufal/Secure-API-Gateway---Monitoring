# API Gateway
GATEWAY_PORT=3000

# Auth Service
AUTH_SERVICE_URL=http://localhost:3001
AUTH_SERVICE_PORT=3001

# Data Service
DATA_SERVICE_URL=http://localhost:3002
DATA_SERVICE_PORT=3002

# Monitoring Service
MONITORING_SERVICE_URL=http://localhost:3003
MONITORING_SERVICE_PORT=3003

# JWT Secret
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secure_gateway
DB_USER=postgres
DB_PASSWORD=postgres_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BRUTE_FORCE_WINDOW_MS=900000
BRUTE_FORCE_MAX_ATTEMPTS=5

# Caching
CACHE_TTL_ITEMS=300
CACHE_TTL_ITEM_DETAIL=600
CACHE_TTL_ACTIVITIES=120

# Anomaly Detection Thresholds
ANOMALY_REQUEST_SPIKE_THRESHOLD=100
ANOMALY_ERROR_SPIKE_THRESHOLD=50
ANOMALY_UNIQUE_IPS_THRESHOLD=50
ANOMALY_FAILED_LOGIN_THRESHOLD=20

# Alert Notifications
WEBHOOK_URL=
WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@secure-gateway.com
ALERT_EMAIL=admin@example.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
